#!/usr/bin/env sh
# Format staged files with Prettier (same rules as CI `pnpm format:check`) and re-stage.
set -eu

cd "$(git rev-parse --show-toplevel)"

files=""
while IFS= read -r -d '' file; do
  [ -f "$file" ] || continue
  files="${files}${file}\0"
done <<EOF
$(git diff --cached --name-only -z --diff-filter=ACMR)
EOF

[ -z "$files" ] && exit 0

printf '%b' "$files" | xargs -0 pnpm exec prettier --write

printf '%b' "$files" | while IFS= read -r -d '' file; do
  git add -- "$file"
done
