#!/usr/bin/env sh
# Format staged files with Prettier (same rules as CI `pnpm format:check`) and re-stage.
set -eu

cd "$(git rev-parse --show-toplevel)"

files=""
while IFS= read -r file; do
  [ -f "$file" ] || continue
  files="$files $file"
done <<EOF
$(git diff --cached --name-only --diff-filter=ACMR)
EOF

[ -z "${files# }" ] || exit 0

# shellcheck disable=SC2086
pnpm exec prettier --write $files

for file in $files; do
  git add -- "$file"
done
