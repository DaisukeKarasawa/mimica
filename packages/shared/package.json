{
  "name": "@mimica/shared",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./character-pack": {
      "types": "./dist/characterPack.d.ts",
      "import": "./dist/characterPack.js",
      "default": "./dist/characterPack.js"
    },
    "./paths": {
      "types": "./dist/mimicaPaths.d.ts",
      "import": "./dist/mimicaPaths.js",
      "default": "./dist/mimicaPaths.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "tsx --test 'src/**/*.test.ts'"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
