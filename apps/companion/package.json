{
  "name": "@mimica/companion",
  "version": "0.1.2",
  "private": true,
  "description": "Mimica Electron Companion App",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "pnpm --filter @mimica/shared build && pnpm --filter @mimica/character-runtime build && pnpm --filter @mimica/agent-orchestrator build && node scripts/run-electron-vite.mjs dev",
    "dev:ui-lab": "pnpm --filter @mimica/shared build && pnpm --filter @mimica/character-runtime build && vite --config vite.ui-lab.config.ts",
    "build": "node scripts/run-electron-vite.mjs build",
    "preview": "node scripts/run-electron-vite.mjs preview",
    "copy-pack": "node scripts/copy-pack.mjs",
    "pack:mac": "CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "package:mac": "pnpm copy-pack && pnpm build && pnpm run pack:mac",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mimica/agent-orchestrator": "workspace:*",
    "@mimica/character-runtime": "workspace:*",
    "@mimica/shared": "workspace:*",
    "@mimica/ui": "workspace:*",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.1",
    "uuid": "^11.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^39.8.5",
    "electron-builder": "^25.1.8",
    "electron-vite": "^5.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.4.2"
  },
  "build": {
    "appId": "dev.mimica.companion",
    "productName": "Mimica",
    "asar": true,
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools"
    },
    "extraResources": [
      {
        "from": "../../templates/persona",
        "to": "templates/persona",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/packs/rio",
        "to": "packs/rio",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
