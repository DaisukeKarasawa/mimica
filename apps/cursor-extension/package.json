{
  "name": "mimica-cursor-extension",
  "displayName": "Mimica",
  "description": "Cursor Agent Companion — launch Mimica external window",
  "version": "0.1.2",
  "private": true,
  "publisher": "mimica-local",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Mimica",
      "properties": {
        "mimica.companionAppPath": {
          "type": "string",
          "scope": "machine",
          "default": "/Applications/Mimica.app",
          "markdownDescription": "Path to the installed Mimica Companion app (.app on macOS). Default matches `@mimica/shared` `MIMICA_COMPANION_APP_DEFAULT_PATH`.",
          "description": "Path to the installed Mimica Companion app (.app on macOS). Used when the extension is not running from the mimica monorepo."
        }
      }
    },
    "commands": [
      {
        "command": "mimica.openCompanion",
        "title": "Mimica: Open Companion"
      },
      {
        "command": "mimica.askAboutSelection",
        "title": "Mimica: Ask About Selection"
      },
      {
        "command": "mimica.askAboutCurrentFile",
        "title": "Mimica: Ask About Current File"
      },
      {
        "command": "mimica.reloadCharacter",
        "title": "Mimica: Reload Character"
      },
      {
        "command": "mimica.openSettings",
        "title": "Mimica: Open Settings"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/bundle-extension.mjs",
    "vscode:prepublish": "pnpm --filter @mimica/shared build && pnpm run build",
    "package:vsix": "vsce package --no-dependencies --allow-missing-repository",
    "dev": "tsc -p tsconfig.json --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "@mimica/shared": "workspace:*",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.13",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.2"
  }
}
