{
  "name": "mimica",
  "private": true,
  "version": "0.1.0",
  "description": "Cursor Agent Companion with character-driven UI",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:companion": "pnpm --filter @mimica/companion dev",
    "dev:extension": "pnpm --filter @mimica/cursor-extension dev",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit": "pnpm audit --audit-level=moderate",
    "security": "pnpm audit --audit-level=moderate && turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
