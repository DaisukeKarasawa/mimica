# Local git worktrees (see using-git-worktrees skill)
.worktrees/

node_modules/
.pnpm-store/
dist/
out/
.turbo/
*.log
.DS_Store
.env
.env.*
!.env.example
*.tsbuildinfo
apps/companion/release/
apps/companion/build/packs/
apps/companion/build/icon.icns
apps/companion/build/icon-dock.png
apps/companion/build/icon.iconset/
apps/companion/build/.icon-source.png
apps/cursor-extension/*.vsix
.vscode-test/

# Python
__pycache__/
*.py[cod]

# Cursor hook runtime state
.cursor/hooks/state/

# Spine / extracted game assets (local only — see docs/spine-asset-guide.md)
*.skel
*.skel.bytes
*.atlas

# Local asset tree if copied or symlinked into the workspace
MimicaAssets/

# Character packs (canonical: mimica-assets repo; see packs/README.md)
packs/*
!packs/README.md

# Persona dialogue (user-provided; may contain third-party game text)
templates/persona/lines.json
templates/persona/lines.source.txt

# Secrets (real keys live outside Git)
**/secrets.json
!templates/secrets.example.json

# Session / conversation persistence
**/sessions/
